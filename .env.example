# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase public client values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase values
# Never expose this value to browser code or NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=

# Storage
SUPABASE_ARTIFACT_BUCKET=artifact-submissions

# Auth transition flags
AUTH_PROVIDER=mock
REPOSITORY_PROVIDER=mock

# Private PostgreSQL target
# Used by the future REPOSITORY_PROVIDER=postgres adapter.
DATABASE_URL=postgresql://ps_track_app:ps_track_app_password@localhost:5432/ps_track
POSTGRES_DB=ps_track
POSTGRES_USER=ps_track_app
POSTGRES_PASSWORD=ps_track_app_password

# AlphaCampus / Keycloak trusted header contract
KEYCLOAK_SUB_HEADER=x-keycloak-sub
KEYCLOAK_USERNAME_HEADER=x-keycloak-preferred-username
KEYCLOAK_EMAIL_HEADER=x-keycloak-email
